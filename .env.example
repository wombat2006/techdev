# Hugging Face Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co

# Server Configuration
PORT=4000
NODE_ENV=development

# Redis Configuration (Upstash)
UPSTASH_REDIS_URL=your_upstash_redis_url_here
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# Database Configuration (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=techsapo

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Cost Management
MONTHLY_BUDGET_LIMIT=70
COST_ALERT_THRESHOLD=0.8

# Japanese Embedding Models (HuggingFace)
EMBEDDING_MODEL_1=cl-tohoku/bert-base-japanese-v3
EMBEDDING_MODEL_2=sonoisa/sentence-bert-base-ja-mean-tokens-v2
EMBEDDING_MODEL_3=colorfulscoop/sbert-base-ja
EMBEDDING_MODEL_4=rinna/japanese-roberta-base
EMBEDDING_MODEL_5=tohoku-nlp/bert-base-japanese-v2