{
  "dashboard": {
    "id": null,
    "title": "TechSapo Operations Dashboard",
    "tags": ["techsapo", "operations", "wallbounce"],
    "style": "dark",
    "timezone": "Asia/Tokyo", 
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Wall-Bounce Analysis Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "techsapo:wallbounce_success_rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.9},
                {"color": "green", "value": 0.95}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Average Consensus Confidence",
        "type": "stat",
        "targets": [
          {
            "expr": "techsapo:wallbounce_avg_confidence_5m",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "green", "value": 0.85}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "P95 Processing Time",
        "type": "stat",
        "targets": [
          {
            "expr": "techsapo:wallbounce_p95_processing_time",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "LLM Error Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(rate(techsapo_llm_requests_total{status=\"error\"}[5m]) / rate(techsapo_llm_requests_total[5m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.01},
                {"color": "red", "value": 0.05}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Wall-Bounce Analysis Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(techsapo_wallbounce_requests_total{status=\"success\"}[5m])",
            "legendFormat": "Success Rate",
            "refId": "A"
          },
          {
            "expr": "techsapo:wallbounce_avg_confidence_5m",
            "legendFormat": "Avg Confidence",
            "refId": "B"
          },
          {
            "expr": "techsapo:wallbounce_p95_processing_time",
            "legendFormat": "P95 Processing Time",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "P95 Processing Time"},
              "properties": [
                {"id": "unit", "value": "s"},
                {"id": "custom.axisPlacement", "value": "right"}
              ]
            }
          ]
        },
        "gridPos": {"h": 9, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "LLM Provider Comparison",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(techsapo_llm_requests_total[5m])",
            "legendFormat": "{{provider}} - {{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Error Rate and Latency Trends",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(techsapo_http_requests_total{status_code=~\"4..|5..\"}[5m])",
            "legendFormat": "HTTP Error Rate",
            "refId": "A"
          },
          {
            "expr": "rate(techsapo_llm_requests_total{status=\"error\"}[5m])",
            "legendFormat": "LLM Error Rate", 
            "refId": "B"
          },
          {
            "expr": "techsapo:http_p95_response_time",
            "legendFormat": "HTTP P95 Latency",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "HTTP P95 Latency"},
              "properties": [
                {"id": "unit", "value": "s"},
                {"id": "custom.axisPlacement", "value": "right"}
              ]
            }
          ]
        },
        "gridPos": {"h": 9, "w": 12, "x": 0, "y": 17}
      },
      {
        "id": 8,
        "title": "Infrastructure Resource Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "techsapo:memory_utilization",
            "legendFormat": "Memory Utilization",
            "refId": "A"
          },
          {
            "expr": "techsapo:active_connection_total",
            "legendFormat": "Active Connections",
            "refId": "B"
          },
          {
            "expr": "techsapo:cache_efficiency", 
            "legendFormat": "Cache Efficiency",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Active Connections"},
              "properties": [
                {"id": "unit", "value": "short"},
                {"id": "custom.axisPlacement", "value": "right"}
              ]
            }
          ]
        },
        "gridPos": {"h": 9, "w": 12, "x": 12, "y": 17}
      },
      {
        "id": 9,
        "title": "Current Active Alerts",
        "type": "table",
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\"}",
            "format": "table",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true
              },
              "renameByName": {
                "alertname": "Alert",
                "severity": "Severity", 
                "service": "Service",
                "description": "Description"
              }
            }
          }
        ],
        "gridPos": {"h": 9, "w": 24, "x": 0, "y": 26}
      }
    ],
    "templating": {
      "list": [
        {
          "name": "provider",
          "type": "query",
          "query": "label_values(techsapo_llm_requests_total, provider)",
          "multi": true,
          "includeAll": true,
          "current": {
            "text": "All",
            "value": ["$__all"]
          }
        },
        {
          "name": "task_type",
          "type": "query", 
          "query": "label_values(techsapo_wallbounce_requests_total, task_type)",
          "multi": true,
          "includeAll": true,
          "current": {
            "text": "All",
            "value": ["$__all"]
          }
        }
      ]
    },
    "links": [
      {
        "title": "Executive Dashboard",
        "url": "/d/techsapo-executive/techsapo-executive-dashboard",
        "type": "dashboards"
      },
      {
        "title": "Development Dashboard",
        "url": "/d/techsapo-development/techsapo-development-dashboard", 
        "type": "dashboards"
      }
    ],
    "schemaVersion": 27,
    "version": 1,
    "uid": "techsapo-operations"
  }
}