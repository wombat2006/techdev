    /** Fast, ephemeral storage backend (Redis, Memory) for caching and temporary data */
    cache: CacheBackend;
    /** Persistent, reliable storage backend (PostgreSQL, SQLite, Memory) for long-term data */
    database: DatabaseBackend;
}
